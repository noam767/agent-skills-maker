# =============================================================================
# Confluence-Driven Agent & Skill Builder — environment configuration
# =============================================================================
# Target deployment: on-prem Confluence Data Center inside an air-gapped network.
# Atlassian Cloud is NOT supported.
# =============================================================================

# Full URL prefix for your on-prem Confluence instance (no trailing slash).
# Examples:
#   CONFLUENCE_BASE_URL=https://confluence.acme.corp
#   CONFLUENCE_BASE_URL=https://intranet.acme.corp/confluence
# The scraper unconditionally appends "/rest/api/..." to this value.
CONFLUENCE_BASE_URL=

# Personal Access Token. Mint from your own profile at:
#   <CONFLUENCE_BASE_URL>/plugins/personalaccesstokens/usertokens.action
# Sent as: Authorization: Bearer <token>
CONFLUENCE_PAT=

# Optional fallback used when --space is not passed on the CLI.
CONFLUENCE_SPACE_KEY=

# -----------------------------------------------------------------------------
# Security note — TLS verification is DISABLED by design.
# -----------------------------------------------------------------------------
# The scraper attaches rejectUnauthorized: false to every HTTPS request so it
# can talk to on-prem Confluence instances served with internally-issued certs
# without requiring CA-bundle provisioning on every developer machine.
#
# This is safe ONLY because the deployment lives inside a closed air-gapped
# network where the operator controls both endpoints. DO NOT point this
# scraper at any host outside that trust boundary.
# -----------------------------------------------------------------------------
