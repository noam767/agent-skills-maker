{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-skills-maker/schemas/scraped-output.schema.json",
  "title": "ScrapedOutput",
  "description": "JSON document emitted on stdout by scripts/scrape-confluence.js.",
  "type": "object",
  "required": ["space", "scrapedAt", "maxDepth", "pageCount", "pages"],
  "additionalProperties": false,
  "properties": {
    "space": {
      "type": "object",
      "required": ["key", "name", "baseUrl"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "pattern": "^[A-Z0-9~]{1,255}$" },
        "name": { "type": "string", "minLength": 1 },
        "baseUrl": { "type": "string", "format": "uri" }
      }
    },
    "scrapedAt": { "type": "string", "format": "date-time" },
    "maxDepth": {
      "description": "Effective max ancestor depth applied. null = unbounded (the default).",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "pageCount": { "type": "integer", "minimum": 0 },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "path", "depth", "labels", "url", "text"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[0-9]+$" },
          "title": { "type": "string", "minLength": 1 },
          "path": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "depth": { "type": "integer", "minimum": 0 },
          "labels": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "url": { "type": "string", "format": "uri" },
          "text": { "type": "string" },
          "attachments": {
            "type": "array",
            "description": "Attachments on this page. Empty when none or when --no-attachments was passed.",
            "items": {
              "type": "object",
              "required": ["id", "title", "mediaType", "fileSize", "kind", "extractionStatus"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[0-9]+$" },
                "title": { "type": "string", "minLength": 1 },
                "mediaType": { "type": "string" },
                "fileSize": { "type": "integer", "minimum": 0 },
                "downloadPath": { "type": "string" },
                "kind": { "enum": ["pdf", "image", "text", "other"] },
                "extractedText": { "type": ["string", "null"] },
                "extractionStatus": {
                  "description": "ok | pending | skipped:<reason> | failed:<reason>",
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
